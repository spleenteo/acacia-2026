# CDA token "CDA Only (Published)" — no preview/CMA access. Used for all
# published-content queries and gql.tada schema generation.
DATOCMS_PUBLISHED_CONTENT_CDA_TOKEN=
# CDA token with preview access (reads drafts). Only used in Draft Mode.
DATOCMS_DRAFT_CONTENT_CDA_TOKEN=
# CMA token. Runtime only needs READ access (Site Search + seo-analysis route):
# on Vercel use the "Read-only API token". Locally a write-capable token is
# fine (needed by scripts/ and POI import).
DATOCMS_CMA_TOKEN=
# DatoCMS environment targeted by the app, codegen and scripts/. Leave empty
# to use the project's primary environment.
DATOCMS_ENVIRONMENT=
# DatoCMS Site Search index id (Site Search → search index). Used by /api/search.
DATOCMS_SITE_SEARCH_INDEX_ID=
DATOCMS_BASE_EDITING_URL=
# Shared secret protecting the webhook/plugin endpoints (invalidate-cache,
# preview-links, seo-analysis, draft-mode/enable). Generate a long random one
# (`openssl rand -hex 32`) and use the same value in the DatoCMS webhook URL
# and Web Previews plugin config.
SECRET_API_TOKEN=
NEXT_PUBLIC_SITE_URL=https://www.acaciafirenze.com
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable
# analytics (e.g. local dev / previews). Set it in the Vercel project env.
NEXT_PUBLIC_GA_ID=
